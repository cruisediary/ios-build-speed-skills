// After: optimized Debug build settings
// These settings maximize incremental build speed

// Only recompiles changed files — essential for fast incremental builds
SWIFT_COMPILATION_MODE = incremental

// Only builds the architecture of the current device/simulator
ONLY_ACTIVE_ARCH = YES

// No optimization in debug — faster compilation
SWIFT_OPTIMIZATION_LEVEL = -Onone

// DWARF only — no dSYM bundle during development (major time saving)
DEBUG_INFORMATION_FORMAT = dwarf

// Testability only on test targets — remove from app target
// ENABLE_TESTABILITY = YES  (move this to your test target's .xcconfig)

// Disables stripping, validation, and symbol copying in Debug
DEPLOYMENT_POSTPROCESSING = NO

// Skip linker dead-strip pass — saves link time with no development benefit
DEAD_CODE_STRIPPING = NO

// Do not strip the binary in Debug — required for the debugger to work correctly
STRIP_INSTALLED_PRODUCT = NO

// Skip Swift symbol stripping post-link step
STRIP_SWIFT_SYMBOLS = NO

// Skip end-of-build product validation
VALIDATE_PRODUCT = NO

// Skip pngcrush on PNG resources — functionally identical, faster builds
COMPRESS_PNG_FILES = NO

// Optimise asset catalog for compile speed instead of bundle size
ASSETCATALOG_COMPILER_OPTIMIZATION = time

// Keep ASan off in default Debug — enable only in a dedicated Sanitize scheme
ENABLE_ADDRESS_SANITIZER = NO
