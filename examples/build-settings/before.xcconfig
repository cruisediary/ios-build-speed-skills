// Before: unoptimized Debug build settings
// These settings result in slow incremental builds

// Recompiles ALL Swift files on every change — worst for incremental builds
SWIFT_COMPILATION_MODE = wholemodule

// Builds for all architectures even during development
ONLY_ACTIVE_ARCH = NO

// Adds optimization overhead to debug builds
SWIFT_OPTIMIZATION_LEVEL = -O

// Generates full dSYM bundle on every debug build (slow)
DEBUG_INFORMATION_FORMAT = dwarf-with-dsym

// Testability overhead on the app target
ENABLE_TESTABILITY = YES

// Master switch: triggers stripping, validation, symbol copying on every build
DEPLOYMENT_POSTPROCESSING = YES

// Extra linker pass to remove dead code — adds link time with no Debug benefit
DEAD_CODE_STRIPPING = YES

// Runs strip on the binary — breaks debugger stepping and wastes time
STRIP_INSTALLED_PRODUCT = YES

// Post-link step that strips Swift-specific symbols — unneeded in Debug
STRIP_SWIFT_SYMBOLS = YES

// Runs architecture and entitlements validation at the end of every build
VALIDATE_PRODUCT = YES

// Runs pngcrush on every PNG resource — slow for asset-heavy projects
COMPRESS_PNG_FILES = YES
