# After: static linkage + warning suppression
# Pods link statically — no dyld load overhead, no embed/codesign per pod

platform :ios, '16.0'

target 'MyApp' do
  use_frameworks! :linkage => :static
  inhibit_all_warnings!

  pod 'Alamofire', '~> 5.9'
  pod 'Kingfisher', '~> 7.0'
  pod 'SnapKit', '~> 5.7'
  pod 'Firebase/Analytics'
  pod 'Firebase/Crashlytics'

  # If a specific pod requires dynamic linkage, use a post_install hook:
  # post_install do |installer|
  #   installer.pods_project.target('SomePod').build_configurations.each do |c|
  #     c.build_settings['MACH_O_TYPE'] = 'mh_dylib'
  #   end
  # end
end
